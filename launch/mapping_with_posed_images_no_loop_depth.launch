<?xml version="1.0"?>
<launch>

<!--This launch file uses posed images for mapping without loop closure-->

  <param name="use_sim_time" value="false"/>

  <arg name="bagfile"  default="/mnt/IVALAB/rosbags/tsrb/20250621/gfgg_video/turtlebot_0.bag /mnt/IVALAB/rosbags/tsrb/20250621/gfgg_video/turtlebot_1.bag"/>
  <arg name="pose_file" default="/mnt/IVALAB/rosbags/tsrb/20250621/gfgg_video/path4/path4_AllFrameTrajectory.txt"/>
  <arg name="odom_topic" default="/rtabmap/odom"/>
  <arg name="camera_frame" default="camera_color_optical_frame"/>

  <arg name="common_args" default="-d --RGBD/CreateOccupancyGrid false --Kp/MaxFeatures -1"/>
  <arg name="cfg" default=""/>
  <arg name="MH_seq" default="false"/> <!-- For MH sequences, the ground truth is coming from a different topic -->
  <arg name="raw_images_for_odom" default="false"/>
  <arg name="record_ground_truth" default="false"/>
  <arg name="rtabmap_viz" default="true"/>
  <arg name="rviz" default="true"/>
  <arg name="output_prefix" default="/tmp/rtabmap"/>

  <!-- rosbag  -->
  <node pkg="rosbag" type="play" name="rosbag" output="screen" args="--clock $(arg bagfile)"/>

  <!-- <node pkg="tf" type="static_transform_publisher" name="cam_base_link" args="0 0 0 1.570796 -1.570796 0 cam0 base_link 10"/> -->
  <!-- <node pkg="tf" type="static_transform_publisher" name="map_to_visual_map" args="0 0 0 -1.570796 0 -1.570796 map visual_map 10"/> -->

  <include file="$(find rtabmap_odom)/launch/rtabmap.launch">
    <arg     if="$(arg raw_images_for_odom)" name="rtabmap_args" value="$(arg common_args) --Rtabmap/ImagesAlreadyRectified false"/>
    <arg unless="$(arg raw_images_for_odom)" name="rtabmap_args" value="$(arg common_args)"/>
    <arg     if="$(arg raw_images_for_odom)" name="odom_args" value="--Rtabmap/ImagesAlreadyRectified false"/>
    <arg     if="$(arg raw_images_for_odom)" name="left_image_topic" value="/cam0/image_raw"/>
    <arg unless="$(arg raw_images_for_odom)" name="left_image_topic" value="/stereo_camera/left/image_rect"/>
    <arg     if="$(arg raw_images_for_odom)" name="right_image_topic" value="/cam1/image_raw"/>
    <arg name="visual_odometry" value="false"/>
    <arg name="stereo" value="false"/>

    <arg name="rgb_topic"               value="/camera/color/image_raw" />
    <arg name="depth_topic"             value="/camera/depth/image_rect_raw" />
    <arg name="camera_info_topic"       value="/camera/color/camera_info" />
    <arg name="depth_camera_info_topic" value="/camera/depth/camera_info" />

    <arg name="frame_id" value="$(arg camera_frame)"/>
    <arg name="wait_for_transform" value="0.1"/>
    <arg if="$(arg record_ground_truth)" name="ground_truth_frame_id" value="world"/>
    <arg if="$(arg record_ground_truth)" name="ground_truth_base_frame_id" value="base_link_gt"/>
    <arg name="cfg" value="$(arg cfg)"/>
    <arg name="clear_params" value="true"/>
    <arg name="imu_topic" value="/imu/data"/>
    <arg name="rtabmap_viz" value="$(arg rtabmap_viz)"/>
    <arg name="rviz" value="$(arg rviz)"/>
    <arg name="wait_imu_to_init" value="false"/>
    <arg name="output_prefix" value="$(arg output_prefix)"/>
    <arg name="database_path" value="/home/yanwei/Desktop/rtabmap.db"/>
    <arg name="approx_sync" value="true" />
  </include>


  <!-- pose publisher node -->
  <node name="pose_publisher" pkg="rtabmap_odom" type="pose_publisher.py" output="screen">
    <remap from="/odom" to="$(arg odom_topic)" />
    <remap from="/left_cam_topic" to="/camera/color/image_raw"/>
    <param name="~pose_file" value="$(arg pose_file)"/>
    <param name="~camera_frame" value="$(arg camera_frame)"/>
  </node>


</launch>
